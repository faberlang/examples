# MiniLM embedding command contract for Stage 2.

importa ex "norma:solum" privata solum
importa ex "norma:processus" privata processus
importa ex "norma:chorda" privata chorda

functio format_jsonne(textus formatum) → bivalens {
    redde formatum ≡ "json"
}

functio json_quote() → textus {
    redde |22| ↦ textus
}

functio json_escape(textus value) → textus {
    fixum textus q ← json_quote()
    fixum textus slash ← |5C| ↦ textus
    varia lista<textus> partes ← vacua
    varia numerus i ← 0
    dum i < value.longitudo() {
        fixum textus c ← value.sectio(i, i + 1)
        si c ≡ q {
            partes.appende(slash + q)
        } sin c ≡ slash {
            partes.appende(slash + slash)
        } sin c ≡ "\n" {
            partes.appende(slash + "n")
        } sin c ≡ "\r" {
            partes.appende(slash + "r")
        } sin c ≡ "\t" {
            partes.appende(slash + "t")
        } secus {
            partes.appende(c)
        }
        i ← i + 1
    }
    redde chorda.nexa(partes, "")
}

functio json_string(textus value) → textus {
    fixum textus q ← json_quote()
    redde q + json_escape(value) + q
}

functio quoted_value(textus line) → textus {
    varia numerus initium ← -1
    varia numerus finis ← -1
    varia numerus i ← 0
    dum i < line.longitudo() {
        si line.sectio(i, i + 1) ≡ "\"" {
            si initium < 0 {
                initium ← i + 1
            } secus {
                finis ← i
                i ← line.longitudo()
            }
        }
        i ← i + 1
    }

    si initium ≥ 0 et finis ≥ initium ergo redde line.sectio(initium, finis)
    redde ""
}

functio subset_field_line(textus line, textus field) → bivalens {
    redde line.initium(field + " = \"") et line.finis("\"")
}

functio subset_field_candidate(textus line, textus field) → bivalens {
    redde line.initium(field + " ") aut line.initium(field + "=")
}

functio subset_line_supported(textus line) → bivalens {
    fixum textus trimmed ← line.recide()
    si trimmed.longitudo() ≡ 0 ergo redde verum
    si trimmed.initium("#") ergo redde verum
    si trimmed ≡ "[[tiers]]" ergo redde verum
    si subset_field_candidate(trimmed, "alias") ergo redde subset_field_line(trimmed, "alias")
    si subset_field_candidate(trimmed, "source") ergo redde subset_field_line(trimmed, "source")
    si subset_field_candidate(trimmed, "status") ergo redde subset_field_line(trimmed, "status")
    si subset_field_candidate(trimmed, "local_path") ergo redde subset_field_line(trimmed, "local_path")
    si subset_field_candidate(trimmed, "router_model_id") ergo redde subset_field_line(trimmed, "router_model_id")
    redde verum
}

functio alias_map_subset_supported(lista<textus> aliases) → bivalens {
    itera ex aliases fixum line {
        si subset_line_supported(line) ≠ verum ergo redde falsum
    }
    redde verum
}

functio map_value(lista<textus> aliases, textus target, textus field) → textus {
    varia bivalens matched ← falsum
    itera ex aliases fixum line {
        fixum textus trimmed ← line.recide()
        si trimmed ≡ "[[tiers]]" {
            matched ← falsum
        }
        si trimmed.initium("alias = ") {
            matched ← quoted_value(trimmed) ≡ target
        }
        si matched et trimmed.initium(field + " = ") {
            redde quoted_value(trimmed)
        }
    }

    redde ""
}

functio status_for(lista<textus> aliases, textus target) → textus {
    fixum textus status ← map_value(aliases, target, "status")
    si status.longitudo() > 0 ergo redde status
    redde "unknown"
}

functio source_for(lista<textus> aliases, textus target) → textus {
    fixum textus source ← map_value(aliases, target, "source")
    si source.longitudo() > 0 ergo redde "" + source
    redde target
}

functio raw_local_path_for(lista<textus> aliases, textus target) → textus {
    redde map_value(aliases, target, "local_path")
}

functio input_count(textus input_path) → numerus {
    fixum lista<textus> lines ← solum.lege<lista<textus>>(input_path)
    varia numerus count ← 0
    itera ex lines fixum line {
        si line.recide().longitudo() > 0 {
            count ← count + 1
        }
    }
    redde count
}

functio embedding_dimensions(textus target) → numerus {
    si target ≡ "mid/qwen3-embed-0.6b" ergo redde 1024
    redde 384
}

functio blocked_diagnostic(textus target) → textus {
    redde "Embedding execution for " + target + " not implemented; use an explicit oracle-backed runner"
}

functio artifact_json(textus target, textus source, numerus count) → textus {
    fixum textus q ← json_quote()
    varia textus out ← "{"
    out ← out + q + "format" + q + ":" + json_string("fvi-stage2") + ","
    out ← out + q + "model" + q + ":" + json_string(target) + ","
    out ← out + q + "source" + q + ":" + json_string(source) + ","
    out ← out + q + "status" + q + ":" + json_string("blocked") + ","
    out ← out + q + "input_count" + q + ":" + (count ↦ textus) + ","
    out ← out + q + "dimensions" + q + ":0,"
    out ← out + q + "normalization" + q + ":" + json_string("pending") + ","
    out ← out + q + "vectors" + q + ":[],"
    out ← out + q + "diagnostics" + q + ":[" + json_string(blocked_diagnostic(target)) + "]"
    out ← out + "}"
    redde out
}

functio emit_json(textus target, textus source, numerus count) → vacuum {
    fixum textus q ← json_quote()
    varia textus out ← "{"
    out ← out + q + "model" + q + ":" + json_string(target) + ","
    out ← out + q + "source" + q + ":" + json_string(source) + ","
    out ← out + q + "status" + q + ":" + json_string("blocked") + ","
    out ← out + q + "input_count" + q + ":" + (count ↦ textus) + ","
    out ← out + q + "dimensions" + q + ":0,"
    out ← out + q + "normalization" + q + ":" + json_string("pending") + ","
    out ← out + q + "vectors_path" + q + ":" + json_string("") + ","
    out ← out + q + "oracle" + q + ":" + json_string("") + ","
    out ← out + q + "diagnostics" + q + ":[" + json_string(blocked_diagnostic(target)) + "]"
    out ← out + "}"
    nota out
}

functio emit_text(textus target, textus source, numerus count) → vacuum {
    nota "model: §"(target)
    nota "source: §"(source)
    nota "status: blocked"
    nota "input_count: §"(count)
    nota "dimensions: 0"
    nota "normalization: pending"
    nota "diagnostic: §"(blocked_diagnostic(target))
}

functio emit_oracle_json(textus target, textus source, numerus count, textus oracle_label) → vacuum {
    fixum textus q ← json_quote()
    fixum numerus dimensions ← embedding_dimensions(target)
    varia textus out ← "{"
    out ← out + q + "model" + q + ":" + json_string(target) + ","
    out ← out + q + "source" + q + ":" + json_string(source) + ","
    out ← out + q + "status" + q + ":" + json_string("oracle-backed") + ","
    out ← out + q + "input_count" + q + ":" + (count ↦ textus) + ","
    out ← out + q + "dimensions" + q + ":" + (dimensions ↦ textus) + ","
    out ← out + q + "normalization" + q + ":" + json_string("l2") + ","
    out ← out + q + "vectors_path" + q + ":" + json_string("") + ","
    out ← out + q + "oracle" + q + ":" + json_string(oracle_label) + ","
    out ← out + q + "diagnostics" + q + ":[" + json_string("vectors produced by explicit oracle runner; Faber-owned transformer execution not implemented") + "]"
    out ← out + "}"
    nota out
}

functio emit_oracle_text(textus target, textus source, numerus count, textus oracle_label) → vacuum {
    nota "model: §"(target)
    nota "source: §"(source)
    nota "status: oracle-backed"
    nota "input_count: §"(count)
    nota "dimensions: §"(embedding_dimensions(target))
    nota "normalization: l2"
    nota "oracle: §"(oracle_label)
    nota "diagnostic: vectors produced by explicit oracle runner; Faber-owned transformer execution not implemented"
}

functio emit_oracle(textus target, textus source, numerus count, textus formatum, textus oracle_label) → vacuum {
    si format_jsonne(formatum) {
        emit_oracle_json(target, source, count, oracle_label)
    } secus {
        emit_oracle_text(target, source, count, oracle_label)
    }
}

functio emit_error_json(textus target, textus diagnosticum) → vacuum {
    fixum textus q ← json_quote()
    varia textus out ← "{"
    out ← out + q + "model" + q + ":" + json_string(target) + ","
    out ← out + q + "source" + q + ":" + json_string(target) + ","
    out ← out + q + "status" + q + ":" + json_string("error") + ","
    out ← out + q + "input_count" + q + ":0,"
    out ← out + q + "dimensions" + q + ":0,"
    out ← out + q + "normalization" + q + ":" + json_string("") + ","
    out ← out + q + "vectors_path" + q + ":" + json_string("") + ","
    out ← out + q + "oracle" + q + ":" + json_string("") + ","
    out ← out + q + "diagnostics" + q + ":[" + json_string(diagnosticum) + "]"
    out ← out + "}"
    nota out
}

functio emit_error_text(textus diagnosticum) → vacuum {
    nota "status: error"
    nota "diagnostic: §"(diagnosticum)
}

functio emit_error(textus target, textus diagnosticum, textus formatum) → vacuum {
    si format_jsonne(formatum) {
        emit_error_json(target, diagnosticum)
    } secus {
        emit_error_text(diagnosticum)
    }
}

functio oracle_args(
    textus runner_path,
    textus input_path,
    textus out_path,
    textus model_dir,
    textus target,
    textus source,
    textus oracle_label,
) → lista<textus> {
    redde [
        "python3",
        runner_path,
        "--texts",
        input_path,
        "--out",
        out_path,
        "--model-dir",
        model_dir,
        "--model-alias",
        target,
        "--source",
        source,
        "--oracle-label",
        oracle_label,
    ]
}

functio result_status(tabula<textus, valor> result) → numerus {
    redde result["status"] ↦ numerus
}

functio result_stdout(tabula<textus, valor> result) → textus {
    redde result["stdout"] ↦ textus
}

functio result_stderr(tabula<textus, valor> result) → textus {
    redde result["stderr"] ↦ textus
}

functio runner_failure(tabula<textus, valor> result) → textus {
    fixum textus stderr ← result_stderr(result).recide()
    si stderr.longitudo() > 0 ergo redde stderr
    redde result_stdout(result).recide()
}

functio artifact_contains(textus out_path, textus marker) → bivalens {
    fixum textus artifact ← solum.lege<textus>(out_path)
    redde artifact.continet(marker)
}

functio curre(
    textus input_path,
    textus target,
    textus out_path,
    textus formatum,
    textus map_path,
    textus oracle_runner,
    textus oracle_label,
) → vacuum {
    si solum.exstat(map_path) ≠ verum {
        emit_error(target, "alias map not found: " + map_path, formatum)
        redde
    }
    si solum.regularene(map_path) ≠ verum aut solum.legibilene(map_path) ≠ verum {
        emit_error(target, "alias map unreadable: " + map_path, formatum)
        redde
    }

    fixum lista<textus> aliases ← solum.lege<lista<textus>>(map_path)
    si alias_map_subset_supported(aliases) ≠ verum {
        emit_error(target, "alias map outside supported subset: " + map_path, formatum)
        redde
    }

    fixum textus status ← status_for(aliases, target)
    si status ≠ "local" {
        emit_error(target, "embedding requires local model alias: " + target, formatum)
        redde
    }

    fixum textus local_path ← raw_local_path_for(aliases, target)
    si local_path.longitudo() ≡ 0 aut solum.exstat(local_path) ≠ verum {
        emit_error(target, "local model file not found: " + target, formatum)
        redde
    }
    si solum.regularene(local_path) ≠ verum aut solum.legibilene(local_path) ≠ verum {
        emit_error(target, "local model file unreadable: " + target, formatum)
        redde
    }
    si solum.exstat(input_path) ≠ verum {
        emit_error(target, "input text file not found: " + input_path, formatum)
        redde
    }
    si solum.regularene(input_path) ≠ verum aut solum.legibilene(input_path) ≠ verum {
        emit_error(target, "input text file unreadable: " + input_path, formatum)
        redde
    }

    fixum numerus count ← input_count(input_path)
    fixum textus source ← source_for(aliases, target)
    si oracle_runner.longitudo() > 0 {
        si solum.exstat(oracle_runner) ≠ verum {
            emit_error(target, "oracle runner not found: " + oracle_runner, formatum)
            redde
        }
        si solum.regularene(oracle_runner) ≠ verum aut solum.legibilene(oracle_runner) ≠ verum {
            emit_error(target, "oracle runner unreadable: " + oracle_runner, formatum)
            redde
        }
        fixum textus model_dir ← solum.parens(local_path)
        si solum.exstat(out_path) {
            solum.dele(out_path)
        }
        fixum tabula<textus, valor> runner_result ← processus.captura(oracle_args(oracle_runner, input_path, out_path, model_dir, target, source, oracle_label)) ↦ tabula<textus, valor>
        si result_status(runner_result) ≠ 0 {
            emit_error(target, "oracle runner failed: " + runner_failure(runner_result), formatum)
            redde
        }
        si solum.exstat(out_path) ≠ verum {
            emit_error(target, "oracle runner did not produce output: " + result_stdout(runner_result), formatum)
            redde
        }
        si solum.regularene(out_path) ≠ verum aut solum.legibilene(out_path) ≠ verum {
            emit_error(target, "oracle runner output unreadable: " + out_path, formatum)
            redde
        }
        si artifact_contains(out_path, "\"status\":\"oracle-backed\"") ≠ verum {
            emit_error(target, "oracle runner output missing oracle-backed status: " + out_path, formatum)
            redde
        }
        emit_oracle(target, source, count, formatum, oracle_label)
        redde
    }

    solum.scribe(out_path, artifact_json(target, source, count))
    si format_jsonne(formatum) {
        emit_json(target, source, count)
    } secus {
        emit_text(target, source, count)
    }
}
