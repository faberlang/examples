# Qwen3 FP8 generative command contract for Stage 6.

importa ex "norma:solum" privata solum
importa ex "norma:processus" privata processus
importa ex "norma:chorda" privata chorda

functio format_jsonne(textus formatum) → bivalens {
    redde formatum ≡ "json"
}

functio json_quote() → textus {
    redde |22| ↦ textus
}

functio json_escape(textus value) → textus {
    fixum textus q ← json_quote()
    fixum textus slash ← |5C| ↦ textus
    varia lista<textus> partes ← vacua
    varia numerus i ← 0
    dum i < value.longitudo() {
        fixum textus c ← value.sectio(i, i + 1)
        si c ≡ q {
            partes.appende(slash + q)
        } sin c ≡ slash {
            partes.appende(slash + slash)
        } sin c ≡ "\n" {
            partes.appende(slash + "n")
        } sin c ≡ "\r" {
            partes.appende(slash + "r")
        } sin c ≡ "\t" {
            partes.appende(slash + "t")
        } secus {
            partes.appende(c)
        }
        i ← i + 1
    }
    redde chorda.nexa(partes, "")
}

functio json_string(textus value) → textus {
    fixum textus q ← json_quote()
    redde q + json_escape(value) + q
}

functio quoted_value(textus line) → textus {
    varia numerus initium ← -1
    varia numerus finis ← -1
    varia numerus i ← 0
    dum i < line.longitudo() {
        si line.sectio(i, i + 1) ≡ "\"" {
            si initium < 0 {
                initium ← i + 1
            } secus {
                finis ← i
                i ← line.longitudo()
            }
        }
        i ← i + 1
    }

    si initium ≥ 0 et finis ≥ initium ergo redde line.sectio(initium, finis)
    redde ""
}

functio subset_field_line(textus line, textus field) → bivalens {
    redde line.initium(field + " = \"") et line.finis("\"")
}

functio subset_field_candidate(textus line, textus field) → bivalens {
    redde line.initium(field + " ") aut line.initium(field + "=")
}

functio subset_line_supported(textus line) → bivalens {
    fixum textus trimmed ← line.recide()
    si trimmed.longitudo() ≡ 0 ergo redde verum
    si trimmed.initium("#") ergo redde verum
    si trimmed ≡ "[[tiers]]" ergo redde verum
    si subset_field_candidate(trimmed, "alias") ergo redde subset_field_line(trimmed, "alias")
    si subset_field_candidate(trimmed, "source") ergo redde subset_field_line(trimmed, "source")
    si subset_field_candidate(trimmed, "status") ergo redde subset_field_line(trimmed, "status")
    si subset_field_candidate(trimmed, "local_path") ergo redde subset_field_line(trimmed, "local_path")
    si subset_field_candidate(trimmed, "router_model_id") ergo redde subset_field_line(trimmed, "router_model_id")
    redde verum
}

functio alias_map_subset_supported(lista<textus> aliases) → bivalens {
    itera ex aliases fixum line {
        si subset_line_supported(line) ≠ verum ergo redde falsum
    }
    redde verum
}

functio map_value(lista<textus> aliases, textus target, textus field) → textus {
    varia bivalens matched ← falsum
    itera ex aliases fixum line {
        fixum textus trimmed ← line.recide()
        si trimmed ≡ "[[tiers]]" {
            matched ← falsum
        }
        si trimmed.initium("alias = ") {
            matched ← quoted_value(trimmed) ≡ target
        }
        si matched et trimmed.initium(field + " = ") {
            redde quoted_value(trimmed)
        }
    }

    redde ""
}

functio status_for(lista<textus> aliases, textus target) → textus {
    fixum textus status ← map_value(aliases, target, "status")
    si status.longitudo() > 0 ergo redde status
    redde "unknown"
}

functio source_for(lista<textus> aliases, textus target) → textus {
    fixum textus source ← map_value(aliases, target, "source")
    si source.longitudo() > 0 ergo redde "" + source
    redde target
}

functio raw_local_path_for(lista<textus> aliases, textus target) → textus {
    redde map_value(aliases, target, "local_path")
}

functio blocked_diagnostic(textus target) → textus {
    redde "Generation execution for " + target + " not implemented; use an explicit oracle-backed runner"
}

functio event_metadata(
    textus target,
    textus source,
    textus status,
    textus oracle_label,
    numerus max_new_tokens,
    textus temperature,
    numerus seed,
) → textus {
    fixum textus q ← json_quote()
    varia textus out ← "{"
    out ← out + q + "event" + q + ":" + json_string("metadata") + ","
    out ← out + q + "model" + q + ":" + json_string(target) + ","
    out ← out + q + "source" + q + ":" + json_string(source) + ","
    out ← out + q + "status" + q + ":" + json_string(status) + ","
    out ← out + q + "runtime" + q + ":" + json_string(oracle_label) + ","
    out ← out + q + "max_new_tokens" + q + ":" + (max_new_tokens ↦ textus) + ","
    out ← out + q + "temperature" + q + ":" + json_string(temperature) + ","
    out ← out + q + "seed" + q + ":" + (seed ↦ textus)
    out ← out + "}"
    redde out
}

functio event_diagnostic(textus diagnosticum) → textus {
    fixum textus q ← json_quote()
    redde "{" + q + "event" + q + ":" + json_string("diagnostic") + "," + q + "message" + q + ":" + json_string(diagnosticum) + "}"
}

functio blocked_artifact(
    textus target,
    textus source,
    textus out_path,
    numerus max_new_tokens,
    textus temperature,
    numerus seed,
) → vacuum {
    fixum textus diagnosticum ← blocked_diagnostic(target)
    fixum textus body ← event_metadata(target, source, "blocked", "", max_new_tokens, temperature, seed) + "\n" + event_diagnostic(diagnosticum) + "\n"
    solum.scribe(out_path, body)
}

functio emit_summary_json(
    textus target,
    textus source,
    textus status,
    textus prompt_path,
    textus out_path,
    bivalens streaming,
    textus oracle_label,
    numerus max_new_tokens,
    textus temperature,
    numerus seed,
    textus diagnosticum,
) → vacuum {
    fixum textus q ← json_quote()
    varia textus out ← "{"
    out ← out + q + "model" + q + ":" + json_string(target) + ","
    out ← out + q + "source" + q + ":" + json_string(source) + ","
    out ← out + q + "status" + q + ":" + json_string(status) + ","
    out ← out + q + "prompt_path" + q + ":" + json_string(prompt_path) + ","
    out ← out + q + "output_path" + q + ":" + json_string(out_path) + ","
    out ← out + q + "streaming" + q + ":" + (streaming ↦ textus) + ","
    out ← out + q + "oracle" + q + ":" + json_string(oracle_label) + ","
    out ← out + q + "max_new_tokens" + q + ":" + (max_new_tokens ↦ textus) + ","
    out ← out + q + "temperature" + q + ":" + json_string(temperature) + ","
    out ← out + q + "seed" + q + ":" + (seed ↦ textus) + ","
    out ← out + q + "diagnostics" + q + ":[" + json_string(diagnosticum) + "]"
    out ← out + "}"
    nota out
}

functio emit_summary_text(
    textus target,
    textus source,
    textus status,
    textus out_path,
    bivalens streaming,
    textus oracle_label,
    textus diagnosticum,
) → vacuum {
    nota "model: §"(target)
    nota "source: §"(source)
    nota "status: §"(status)
    nota "output_path: §"(out_path)
    nota "streaming: §"(streaming)
    si oracle_label.longitudo() > 0 {
        nota "oracle: §"(oracle_label)
    }
    nota "diagnostic: §"(diagnosticum)
}

functio emit_summary(
    textus target,
    textus source,
    textus status,
    textus prompt_path,
    textus out_path,
    bivalens streaming,
    textus oracle_label,
    numerus max_new_tokens,
    textus temperature,
    numerus seed,
    textus diagnosticum,
    textus formatum,
) → vacuum {
    si format_jsonne(formatum) {
        emit_summary_json(target, source, status, prompt_path, out_path, streaming, oracle_label, max_new_tokens, temperature, seed, diagnosticum)
    } secus {
        emit_summary_text(target, source, status, out_path, streaming, oracle_label, diagnosticum)
    }
}

functio emit_error(textus target, textus source, textus diagnosticum, textus formatum) → vacuum {
    emit_summary(target, source, "error", "", "", falsum, "", 0, "0", 0, diagnosticum, formatum)
}

functio oracle_args(
    textus runner_path,
    textus prompt_path,
    textus out_path,
    textus model_dir,
    textus target,
    textus source,
    textus oracle_label,
    numerus max_new_tokens,
    textus temperature,
    numerus seed,
) → lista<textus> {
    redde [
        "python3",
        runner_path,
        "--prompt",
        prompt_path,
        "--out",
        out_path,
        "--model-dir",
        model_dir,
        "--model-alias",
        target,
        "--source",
        source,
        "--oracle-label",
        oracle_label,
        "--max-new-tokens",
        max_new_tokens ↦ textus,
        "--temperature",
        temperature,
        "--seed",
        seed ↦ textus,
    ]
}

functio result_status(tabula<textus, valor> result) → numerus {
    redde result["status"] ↦ numerus
}

functio result_stdout(tabula<textus, valor> result) → textus {
    redde result["stdout"] ↦ textus
}

functio result_stderr(tabula<textus, valor> result) → textus {
    redde result["stderr"] ↦ textus
}

functio runner_failure(tabula<textus, valor> result) → textus {
    fixum textus stderr ← result_stderr(result).recide()
    si stderr.longitudo() > 0 ergo redde stderr
    redde result_stdout(result).recide()
}

functio artifact_contains(textus out_path, textus marker) → bivalens {
    fixum textus artifact ← solum.lege<textus>(out_path)
    redde artifact.continet(marker)
}

functio curre(
    textus prompt_path,
    textus target,
    textus out_path,
    textus formatum,
    textus map_path,
    textus oracle_runner,
    textus oracle_label,
    numerus max_new_tokens,
    textus temperature,
    numerus seed,
) → vacuum {
    si solum.exstat(map_path) ≠ verum {
        emit_error(target, target, "alias map not found: " + map_path, formatum)
        redde
    }
    si solum.regularene(map_path) ≠ verum aut solum.legibilene(map_path) ≠ verum {
        emit_error(target, target, "alias map unreadable: " + map_path, formatum)
        redde
    }

    fixum lista<textus> aliases ← solum.lege<lista<textus>>(map_path)
    si alias_map_subset_supported(aliases) ≠ verum {
        emit_error(target, target, "alias map outside supported subset: " + map_path, formatum)
        redde
    }

    fixum textus source ← source_for(aliases, target)
    fixum textus status ← status_for(aliases, target)
    si status ≠ "local" {
        emit_error(target, source, "generation requires local model alias: " + target, formatum)
        redde
    }

    fixum textus local_path ← raw_local_path_for(aliases, target)
    si local_path.longitudo() ≡ 0 aut solum.exstat(local_path) ≠ verum {
        emit_error(target, source, "local model index not found: " + target, formatum)
        redde
    }
    si solum.regularene(local_path) ≠ verum aut solum.legibilene(local_path) ≠ verum {
        emit_error(target, source, "local model index unreadable: " + target, formatum)
        redde
    }
    si solum.exstat(prompt_path) ≠ verum {
        emit_error(target, source, "prompt file not found: " + prompt_path, formatum)
        redde
    }
    si solum.regularene(prompt_path) ≠ verum aut solum.legibilene(prompt_path) ≠ verum {
        emit_error(target, source, "prompt file unreadable: " + prompt_path, formatum)
        redde
    }

    si oracle_runner.longitudo() ≡ 0 {
        blocked_artifact(target, source, out_path, max_new_tokens, temperature, seed)
        emit_summary(target, source, "blocked", prompt_path, out_path, falsum, "", max_new_tokens, temperature, seed, blocked_diagnostic(target), formatum)
        redde
    }

    si solum.exstat(oracle_runner) ≠ verum {
        emit_error(target, source, "oracle runner not found: " + oracle_runner, formatum)
        redde
    }
    si solum.regularene(oracle_runner) ≠ verum aut solum.legibilene(oracle_runner) ≠ verum {
        emit_error(target, source, "oracle runner unreadable: " + oracle_runner, formatum)
        redde
    }

    si solum.exstat(out_path) {
        solum.dele(out_path)
    }
    fixum textus model_dir ← solum.parens(local_path)
    fixum tabula<textus, valor> runner_result ← processus.captura(oracle_args(oracle_runner, prompt_path, out_path, model_dir, target, source, oracle_label, max_new_tokens, temperature, seed)) ↦ tabula<textus, valor>
    si result_status(runner_result) ≠ 0 {
        emit_error(target, source, "oracle runner failed: " + runner_failure(runner_result), formatum)
        redde
    }
    si solum.exstat(out_path) ≠ verum {
        emit_error(target, source, "oracle runner did not produce output: " + result_stdout(runner_result), formatum)
        redde
    }
    si solum.regularene(out_path) ≠ verum aut solum.legibilene(out_path) ≠ verum {
        emit_error(target, source, "oracle runner output unreadable: " + out_path, formatum)
        redde
    }
    si artifact_contains(out_path, "\"status\":\"oracle-backed\"") ≠ verum {
        emit_error(target, source, "oracle runner output missing oracle-backed status: " + out_path, formatum)
        redde
    }

    emit_summary(target, source, "oracle-backed", prompt_path, out_path, verum, oracle_label, max_new_tokens, temperature, seed, "generated by explicit oracle runner; Faber-owned transformer execution not implemented", formatum)
}
