# Model inventory and metadata commands for the Faber AI workbench.

importa ex "norma:solum" privata solum
importa ex "norma:model" privata model

@ json
@ privata
genus ModelTensorRecord {
    @ json { nomen = "name" }
    textus nomen
    textus dtype
    @ json { nomen = "shape" }
    lista<numerus> figura
    @ json { nomen = "parameter_count" }
    numerus parameter_count
}

@ json
@ privata
genus ModelInspectResponse {
    textus alias
    textus source
    textus status
    @ json { nomen = "format" }
    textus formatum
    @ json { nomen = "local_path" }
    textus local_path
    @ json { nomen = "router_model_id" }
    textus router_model_id
    lista<textus> files
    lista<ModelTensorRecord> tensors
    @ json { nomen = "tensor_count" }
    numerus tensor_count
    lista<textus> shards
    textus quantization
    @ json { nomen = "estimated_bytes" }
    numerus estimated_bytes
    lista<textus> diagnostics
}

functio format_jsonne(textus formatum) → bivalens {
    redde formatum ≡ "json"
}

functio quoted_value(textus line) → textus {
    varia numerus initium ← -1
    varia numerus finis ← -1
    varia numerus i ← 0
    dum i < line.longitudo() {
        si line.sectio(i, i + 1) ≡ "\"" {
            si initium < 0 {
                initium ← i + 1
            } secus {
                finis ← i
                i ← line.longitudo()
            }
        }
        i ← i + 1
    }

    si initium ≥ 0 et finis ≥ initium ergo redde line.sectio(initium, finis)
    redde ""
}

functio subset_field_line(textus line, textus field) → bivalens {
    fixum textus q ← |22| ↦ textus
    redde line.initium("§ = §"(field, q)) et line.finis(q)
}

functio subset_field_candidate(textus line, textus field) → bivalens {
    redde line.initium("§ "(field)) aut line.initium("§="(field))
}

functio subset_line_supported(textus line) → bivalens {
    fixum textus trimmed ← line.recide()
    si trimmed.longitudo() ≡ 0 ergo redde verum
    si trimmed.initium("#") ergo redde verum
    si trimmed ≡ "[[tiers]]" ergo redde verum
    si subset_field_candidate(trimmed, "alias") ergo redde subset_field_line(trimmed, "alias")
    si subset_field_candidate(trimmed, "source") ergo redde subset_field_line(trimmed, "source")
    si subset_field_candidate(trimmed, "status") ergo redde subset_field_line(trimmed, "status")
    si subset_field_candidate(trimmed, "local_path") ergo redde subset_field_line(trimmed, "local_path")
    si subset_field_candidate(trimmed, "router_model_id") ergo redde subset_field_line(trimmed, "router_model_id")
    redde verum
}

functio alias_map_subset_supported(lista<textus> aliases) → bivalens {
    itera ex aliases fixum line {
        si subset_line_supported(line) ≠ verum ergo redde falsum
    }
    redde verum
}

functio map_value(lista<textus> aliases, textus target, textus field) → textus {
    varia bivalens matched ← falsum
    itera ex aliases fixum line {
        fixum textus trimmed ← line.recide()
        si trimmed ≡ "[[tiers]]" {
            matched ← falsum
        }
        si trimmed.initium("alias = ") {
            matched ← quoted_value(trimmed) ≡ target
        }
        si matched et trimmed.initium("§ = "(field)) {
            redde quoted_value(trimmed)
        }
    }

    redde ""
}

functio status_for(lista<textus> aliases, textus target) → textus {
    fixum textus status ← map_value(aliases, target, "status")
    si status.longitudo() > 0 ergo redde status
    redde "unknown"
}

functio source_for(lista<textus> aliases, textus target) → textus {
    fixum textus source ← map_value(aliases, target, "source")
    si source.longitudo() > 0 ergo redde source
    redde target
}

functio local_path_for(lista<textus> aliases, textus target) → textus {
    fixum textus localis ← raw_local_path_for(aliases, target)
    si localis.longitudo() > 0 ergo redde ""
    redde ""
}

functio raw_local_path_for(lista<textus> aliases, textus target) → textus {
    fixum textus localis ← map_value(aliases, target, "local_path")
    redde localis
}

functio router_id_for(lista<textus> aliases, textus target) → textus {
    redde map_value(aliases, target, "router_model_id")
}

functio format_for(lista<textus> aliases, textus target) → textus {
    redde model.formatum(status_for(aliases, target), source_for(aliases, target))
}

functio diagnostic_for(lista<textus> aliases, textus target) → textus {
    redde model.diagnosticum(status_for(aliases, target), source_for(aliases, target), router_id_for(aliases, target))
}

functio test_aliases() → lista<textus> {
    redde [
        "[[tiers]]",
        "alias = \"basic/minilm\"",
        "status = \"missing-download\"",
        "source = \"sentence-transformers/all-MiniLM-L6-v2\"",
        "local_path = \"\"",
        "router_model_id = \"\"",
        "[[tiers]]",
        "alias = \"daily/qwen36-35b-a3b-q4\"",
        "status = \"router-backed\"",
        "source = \"unsloth/Qwen3.6-35B-A3B-GGUF\"",
        "local_path = \"/redacted/local.gguf\"",
        "router_model_id = \"qwen36-35b-a3b-q4\"",
    ]
}

functio test_invalid_aliases() → lista<textus> {
    redde [
        "[[tiers]]",
        "alias=\"basic/minilm\"",
        "status = \"missing-download\"",
        "source = \"sentence-transformers/all-MiniLM-L6-v2\"",
        "local_path = \"\"",
        "router_model_id = \"\"",
    ]
}

probandum "model alias inspection" tag "ai-workbench" {
    proba "Tier 1 MiniLM is marked as missing local download" {
        fixum lista<textus> aliases ← test_aliases()
        adfirma status_for(aliases, "basic/minilm") ≡ "missing-download"
        adfirma source_for(aliases, "basic/minilm") ≡ "sentence-transformers/all-MiniLM-L6-v2"
        adfirma format_for(aliases, "basic/minilm") ≡ "alias-missing"
    }

    proba "Tier 4 Qwen router alias records redacted GGUF state" {
        fixum lista<textus> aliases ← test_aliases()
        adfirma status_for(aliases, "daily/qwen36-35b-a3b-q4") ≡ "router-backed"
        adfirma router_id_for(aliases, "daily/qwen36-35b-a3b-q4") ≡ "qwen36-35b-a3b-q4"
        adfirma local_path_for(aliases, "daily/qwen36-35b-a3b-q4") ≡ ""
        adfirma format_for(aliases, "daily/qwen36-35b-a3b-q4") ≡ "gguf"
    }

    proba "unknown model target fails closed" {
        fixum lista<textus> aliases ← test_aliases()
        adfirma status_for(aliases, "not/a-known-alias") ≡ "unknown"
        adfirma diagnostic_for(aliases, "not/a-known-alias") ≡ "unknown alias or unsupported path"
    }

    proba "alias map subset rejects valid TOML outside the Stage A dialect" {
        adfirma alias_map_subset_supported(test_aliases()) ≡ verum
        adfirma alias_map_subset_supported(test_invalid_aliases()) ≡ falsum
    }
}

functio inspect_json(lista<textus> aliases, textus target) → vacuum {
    fixum textus source ← source_for(aliases, target)
    fixum textus status ← status_for(aliases, target)
    fixum textus formatum ← format_for(aliases, target)
    fixum textus local_path ← local_path_for(aliases, target)
    fixum textus router_id ← router_id_for(aliases, target)
    fixum textus diagnosticum ← diagnostic_for(aliases, target)
    nota render_model_response(ModelInspectResponse {
        alias = target,
        source = source,
        status = status,
        formatum = formatum,
        local_path = local_path,
        router_model_id = router_id,
        files = [],
        tensors = [],
        tensor_count = 0,
        shards = [],
        quantization = "",
        estimated_bytes = 0,
        diagnostics = [diagnosticum]
    })
}

functio inspect_text(lista<textus> aliases, textus target) → vacuum {
    nota "alias: §"(target)
    nota "source: §"(source_for(aliases, target))
    nota "status: §"(status_for(aliases, target))
    nota "format: §"(format_for(aliases, target))
    si local_path_for(aliases, target).longitudo() > 0 {
        nota "local_path: §"(local_path_for(aliases, target))
    }
    si router_id_for(aliases, target).longitudo() > 0 {
        nota "router_model_id: §"(router_id_for(aliases, target))
    }
    nota "diagnostic: §"(diagnostic_for(aliases, target))
}

functio json_numerus_lista(lista<numerus> items) → textus {
    varia textus out ← "["
    varia numerus i ← 0
    itera ex items fixum item {
        si i > 0 {
            out ← "§,"(out)
        }
        out ← "§§"(out, item ↦ textus)
        i ← i + 1
    }
    redde "§]"(out)
}

@ privata
functio render_model_response(ModelInspectResponse response) → textus {
    fac {
        redde (response ↦ json) ↦ textus
    }
    cape err {
        redde "{\"alias\":\"\",\"diagnostics\":[\"json render failed\"],\"estimated_bytes\":0,\"files\":[],\"format\":\"unknown\",\"local_path\":\"\",\"quantization\":\"\",\"router_model_id\":\"\",\"shards\":[],\"source\":\"\",\"status\":\"error\",\"tensor_count\":0,\"tensors\":[]}"
    }
}

functio inspect_error_json(textus target, textus source, textus formatum, textus local_path, textus router_id, textus diagnosticum) → vacuum {
    nota render_model_response(ModelInspectResponse {
        alias = target,
        source = source,
        status = "error",
        formatum = formatum,
        local_path = local_path,
        router_model_id = router_id,
        files = [],
        tensors = [],
        tensor_count = 0,
        shards = [],
        quantization = "",
        estimated_bytes = 0,
        diagnostics = [diagnosticum]
    })
}

functio output_files(lista<textus> files, textus display_path) → lista<textus> {
    si display_path.longitudo() ≡ 0 ergo redde vacua
    redde files
}

functio output_diagnostic(textus nuntius, textus display_path) → textus {
    si display_path.longitudo() ≡ 0 et nuntius.finis("beside ") {
        redde "tokenizer/config sibling probe skipped for redacted local path"
    }
    redde nuntius
}

functio gguf_quantization_for(textus read_path, textus router_model_id, textus summary_quantization) → textus {
    si summary_quantization ≠ "FILE_TYPE_-1" ergo redde summary_quantization
    si router_model_id.longitudo() ≡ 0 ergo redde summary_quantization
    fixum numerus offset ← solum.inveni(read_path, "general.file_type", 0, 12000000)
    si offset < 0 ergo redde summary_quantization
    fixum octeti fragment ← solum.partem(read_path, offset, 64)
    redde model.gguf_quantization_fragmentum(fragment)
}

functio inspect_local_safetensors(textus alias, textus source, textus read_path, textus display_path, textus formatum) → vacuum {
    fac {
        fixum octeti data ← solum.partem(read_path, 0, 16777216)
        fixum _ summary ← model.tempta_safetensors_summarium(alias, source, display_path, data)
        si format_jsonne(formatum) {
            varia lista<ModelTensorRecord> tensors ← vacua
            itera ex summary.tensors fixum tensor {
                tensors.appende(ModelTensorRecord {
                    nomen = tensor.nomen,
                    dtype = tensor.dtype,
                    figura = tensor.figura,
                    parameter_count = tensor.parameter_count
                })
            }

            varia lista<textus> diagnostics ← vacua
            itera ex summary.diagnostics fixum diagnostic {
                diagnostics.appende(output_diagnostic(diagnostic.nuntius, display_path))
            }
            nota render_model_response(ModelInspectResponse {
                alias = summary.alias,
                source = summary.source,
                status = summary.status,
                formatum = summary.formatum,
                local_path = summary.local_path,
                router_model_id = "",
                files = output_files(summary.files, display_path),
                tensors = tensors,
                tensor_count = summary.tensor_count,
                shards = summary.shards,
                quantization = summary.quantization,
                estimated_bytes = summary.estimated_bytes,
                diagnostics = diagnostics
            })
        } secus {
            nota "alias: §"(summary.alias)
            nota "source: §"(summary.source)
            nota "status: §"(summary.status)
            nota "format: §"(summary.formatum)
            nota "local_path: §"(summary.local_path)
            nota "tensor_count: §"(summary.tensor_count)
            nota "estimated_bytes: §"(summary.estimated_bytes)
            itera ex summary.tensors fixum tensor {
                nota "tensor: § § §"(tensor.nomen, tensor.dtype, json_numerus_lista(tensor.figura))
            }
            itera ex summary.diagnostics fixum diagnostic {
                nota "diagnostic: §"(output_diagnostic(diagnostic.nuntius, display_path))
            }
        }
    }
    cape err {
        si format_jsonne(formatum) {
            inspect_error_json(alias, source, "safetensors", display_path, "", "safetensors metadata error: §"(err.nuntius))
        } secus {
            nota "alias: §"(alias)
            nota "source: §"(source)
            nota "status: error"
            nota "format: safetensors"
            nota "local_path: §"(display_path)
            nota "diagnostic: safetensors metadata error: §"(err.nuntius)
        }
    }
}

functio inspect_local_gguf(textus alias, textus source, textus read_path, textus display_path, textus router_model_id, textus formatum) → vacuum {
    fixum textus router_id_output ← "§"(router_model_id)
    fac {
        varia numerus prefix_bytes ← 16777216
        si router_id_output.longitudo() > 0 et display_path.longitudo() ≡ 0 {
            prefix_bytes ← 65536
        }
        fixum octeti data ← solum.partem(read_path, 0, prefix_bytes)
        fixum numerus file_size ← solum.mensura(read_path)
        fixum _ summary ← model.tempta_gguf_summarium(alias, source, display_path, router_id_output, data, file_size)
        fixum textus quantization_text ← gguf_quantization_for(read_path, router_id_output, summary.quantization)
        si format_jsonne(formatum) {
            varia lista<ModelTensorRecord> tensors ← vacua
            itera ex summary.tensors fixum tensor {
                tensors.appende(ModelTensorRecord {
                    nomen = tensor.nomen,
                    dtype = tensor.dtype,
                    figura = tensor.figura,
                    parameter_count = tensor.parameter_count
                })
            }

            varia lista<textus> diagnostics ← vacua
            itera ex summary.diagnostics fixum diagnostic {
                diagnostics.appende(diagnostic.nuntius)
            }
            nota render_model_response(ModelInspectResponse {
                alias = summary.alias,
                source = summary.source,
                status = summary.status,
                formatum = summary.formatum,
                local_path = summary.local_path,
                router_model_id = "§"(router_id_output),
                files = summary.files,
                tensors = tensors,
                tensor_count = summary.tensor_count,
                shards = summary.shards,
                quantization = quantization_text,
                estimated_bytes = summary.estimated_bytes,
                diagnostics = diagnostics
            })
        } secus {
            nota "alias: §"(summary.alias)
            nota "source: §"(summary.source)
            nota "status: §"(summary.status)
            nota "format: §"(summary.formatum)
            nota "local_path: §"(summary.local_path)
            si router_id_output.longitudo() > 0 {
                nota "router_model_id: §"(router_id_output)
            }
            nota "tensor_count: §"(summary.tensor_count)
            nota "quantization: §"(quantization_text)
            nota "estimated_bytes: §"(summary.estimated_bytes)
            itera ex summary.tensors fixum tensor {
                nota "tensor: § § §"(tensor.nomen, tensor.dtype, json_numerus_lista(tensor.figura))
            }
            itera ex summary.diagnostics fixum diagnostic {
                nota "diagnostic: §"(diagnostic.nuntius)
            }
        }
    }
    cape err {
        si format_jsonne(formatum) {
            inspect_error_json(alias, source, "gguf", display_path, router_id_output, "gguf metadata error: §"(err.nuntius))
        } secus {
            nota "alias: §"(alias)
            nota "source: §"(source)
            nota "status: error"
            nota "format: gguf"
            nota "local_path: §"(display_path)
            si router_id_output.longitudo() > 0 {
                nota "router_model_id: §"(router_id_output)
            }
            nota "diagnostic: gguf metadata error: §"(err.nuntius)
        }
    }
}

functio inspect_map_missing_json(textus target, textus map_path) → vacuum {
    inspect_error_json(target, map_path, "unknown", "", "", "alias map not found: §"(map_path))
}

functio inspect_map_missing_text(textus target, textus map_path) → vacuum {
    nota "alias: §"(target)
    nota "source: §"(map_path)
    nota "status: error"
    nota "format: unknown"
    nota "diagnostic: alias map not found: §"(map_path)
}

functio inspect_map_unreadable_json(textus target, textus map_path) → vacuum {
    inspect_error_json(target, map_path, "unknown", "", "", "alias map unreadable: §"(map_path))
}

functio inspect_map_unreadable_text(textus target, textus map_path) → vacuum {
    nota "alias: §"(target)
    nota "source: §"(map_path)
    nota "status: error"
    nota "format: unknown"
    nota "diagnostic: alias map unreadable: §"(map_path)
}

functio inspect_map_invalid_json(textus target, textus map_path) → vacuum {
    inspect_error_json(target, map_path, "unknown", "", "", "alias map outside supported subset: §"(map_path))
}

functio inspect_map_invalid_text(textus target, textus map_path) → vacuum {
    nota "alias: §"(target)
    nota "source: §"(map_path)
    nota "status: error"
    nota "format: unknown"
    nota "diagnostic: alias map outside supported subset: §"(map_path)
}

@ imperium "inspect"
@ descriptio "Inspect model alias or local model metadata"
@ optio format longum "format" typus textus vel "text" descriptio "Output format: text or json"
@ optio map longum "alias-map" typus textus vel "docs/campaigns/ai-workbench/model-aliases.toml" descriptio "Alias map TOML path"
@ operandus textus target descriptio "Model alias or local file path"
functio inspect() argumenta args → vacuum {
    fixum textus map_path ← "§"(args.map)
    fixum textus target ← "§"(args.target)
    fixum textus output_format ← "§"(args.format)
    si solum.exstat(target) et solum.regularene(target) et solum.legibilene(target) {
        si model.formatum("local", target) ≡ "safetensors" {
            inspect_local_safetensors(target, target, target, target, output_format)
            redde
        }
        si model.formatum("local", target) ≡ "gguf" {
            inspect_local_gguf(target, target, target, target, "", output_format)
            redde
        }
    }

    si solum.exstat(map_path) ≠ verum {
        si format_jsonne(output_format) {
            inspect_map_missing_json(target, map_path)
        } secus {
            inspect_map_missing_text(target, map_path)
        }
        redde
    }
    si solum.regularene(map_path) ≠ verum aut solum.legibilene(map_path) ≠ verum {
        si format_jsonne(output_format) {
            inspect_map_unreadable_json(target, map_path)
        } secus {
            inspect_map_unreadable_text(target, map_path)
        }
        redde
    }

    fixum lista<textus> aliases ← solum.carpe(map_path)
    si alias_map_subset_supported(aliases) ≠ verum {
        si format_jsonne(output_format) {
            inspect_map_invalid_json(target, map_path)
        } secus {
            inspect_map_invalid_text(target, map_path)
        }
        redde
    }

    fixum textus raw_local_path ← raw_local_path_for(aliases, target)
    si status_for(aliases, target) ≡ "local" et raw_local_path.finis(".safetensors") {
        si solum.exstat(raw_local_path) et solum.regularene(raw_local_path) et solum.legibilene(raw_local_path) {
            inspect_local_safetensors(target, source_for(aliases, target), raw_local_path, "", output_format)
            redde
        }
    }
    si status_for(aliases, target) ≡ "router-backed" et format_for(aliases, target) ≡ "gguf" et raw_local_path.longitudo() > 0 {
        si solum.exstat(raw_local_path) et solum.regularene(raw_local_path) et solum.legibilene(raw_local_path) {
            inspect_local_gguf(target, source_for(aliases, target), raw_local_path, "", router_id_for(aliases, target), output_format)
            redde
        }
    }

    si format_jsonne(output_format) {
        inspect_json(aliases, target)
    } secus {
        inspect_text(aliases, target)
    }
}
