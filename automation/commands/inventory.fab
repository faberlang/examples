# =============================================================================
# inventory — automation inventory commands
# =============================================================================
#
# What this example teaches:
#   • @ imperium — Defining a CLI subcommand within a module
#     (lines 11, 23, 34)
#   • @ operandus — Annotating positional operands on commands
#     (lines 24, 35)
#   • functio with argumenta args — Command handler receiving parent CLI
#     options through args (lines 14, 26, 37)
#
# Syntaxes used:
#   • @ imperium — command annotation (lines 11, 23, 34)
#   • @ descriptio — command description annotation (lines 12, 24, 35)
#   • @ operandus — operand annotation (lines 24, 35)
#   • functio — function definitions (throughout)
#   • argumenta args — CLI option binding in function signature
#   • probandum / proba / adfirma — test suite (lines 41–51)
#   • nota — standard output
#   • textus — string type
#   • bivalens — boolean type
#   • ≡ — equality comparison
#
# Alternate approaches (not shown):
#   • @ imperium subcommand vs route() dispatch — @ imperium used
#     here for typed subcommands; route() dispatch when commands
#     share a flat namespace
#
# Anti-patterns (avoid these):
#   • Hardcoding fixture data in commands — prefer resource
#     files or context injection
#   • @ imperium on non-function — @ imperium may only annotate
#     a functio declaration
#
# Learning path:
#   Before: coreutils CLI patterns
#   After:  vivilite
#
# Stage: imperium list/show/check with probandum tests, fixture stubs
# Backend: both (stepper + Rust)
# =============================================================================

functio sample_record_line() → textus {
    redde "sample-automation  PAUSED  codex  RRULE:FREQ=HOURLY;INTERVAL=1;BYMINUTE=0"
}

functio sample_status() → textus {
    redde "PAUSED"
}

@ imperium "list"
@ descriptio "List automation skill records"
functio list() argumenta args → vacuum {
    nota "root: §"(args.root)
    si args.verbose {
        nota "mode: inventory list"
    }
    nota sample_record_line()
}

@ imperium "show"
@ descriptio "Show one automation record"
@ operandus textus id descriptio "Automation id"
functio show() argumenta args → vacuum {
    nota "id: §"(args.id)
    nota "root: §"(args.root)
    nota "status: §"(sample_status())
    nota "execute: codex"
    nota "model: gpt-5.4-mini"
}

@ imperium "check"
@ descriptio "Validate one automation record"
@ operandus textus id descriptio "Automation id"
functio check() argumenta args → vacuum {
    nota "checking: §"(args.id)
    si args.verbose {
        nota "required fields: id, kind, execute, status, rrule, model, reasoning_effort, cwds"
    }
    nota "ok: fixture metadata shape is valid"
}

probandum "automation inventory" tag "automation" {
    proba "sample record line names the paused fixture" {
        adfirma sample_record_line() ≡ "sample-automation  PAUSED  codex  RRULE:FREQ=HOURLY;INTERVAL=1;BYMINUTE=0"
    }

    proba "sample status is paused" {
        adfirma sample_status() ≡ "PAUSED"
    }
}
