+++
term = "sparsa"
kind = "smoke"
category = "collection"
canonical = false
summary = "Sparse tensor codegen smoke for longitudo and nonnihil calls."
syntax = "sparsa<T, Figura>.longitudo() | sparsa<T, Figura>.nonnihil()"
related = ["sparsa", "tensor", "vacua"]
+++

incipit {
  fixum sparsa<fractus, [2, 3]> s ← vacua
  fixum _ len ← s.longitudo()
  fixum _ count ← s.nonnihil()
  nota len, count
}
