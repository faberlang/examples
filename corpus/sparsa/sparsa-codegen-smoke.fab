+++
term = "sparsa"
kind = "smoke"
category = "collection"
canonical = false
summary = "Sparse tensor codegen smoke for longitudo and nonnihil calls."
syntax = "sparsa<T, Figura>.longitudo() | sparsa<T, Figura>.nonnihil()"
