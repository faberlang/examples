+++

# =============================================================================
# sparsa — Sparse tensor codegen smoke for longitudo and nonnihil calls.
# =============================================================================
#
# What this teaches:
#   • Sparse tensor intrinsics — `longitudo()` for rank and `nonnihil()` for stored element count
#   • Codegen smoke — minimal proof that sparse tensor operations produce executable code
#
# Common mistakes:
#   • confusing longitudo() (rank) with nonnihil() (stored nonzero count)
#
# See also: sparsa, tensor, vacua
# =============================================================================

incipit {
  fixum sparsa<fractus, [2, 3]> s ← vacua
  fixum _ len ← s.longitudo()
  fixum _ count ← s.nonnihil()
  nota len, count
}
