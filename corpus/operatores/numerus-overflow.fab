+++
term = "numerus"
kind = "operator-group"
category = "arithmetic"
canonical = true
summary = "Checked numerus arithmetic traps instead of wrapping on overflow."
syntax = "<numerus> + <numerus>"
related = ["+", "numerus"]
+++

# numerus-overflow — checked scalar arithmetic failure
#
# POLICY:
#   Bare `numerus` is i64. Integer arithmetic traps on overflow; it does not
#   inherit Rust release wrapping.

incipit {
    fixum numerus max ← 9223372036854775807
    nota max + 1
}
