+++
term = "falsum"
kind = "keyword"
category = "boolean"
canonical = true
summary = "Represents the false boolean value and can prefix a falsity check."
syntax = "falsum [<expression>]"
related = ["verum", "nihil"]
+++

# falsum — false literal
#
# GRAMMAR:
#   literal :← 'falsum'
#
# EXPECTED OUTPUT:
#   Scalar stdout smoke (see body).
#

incipit {
    fixum _ inactive ← falsum
    nota inactive
}
