# =============================================================================
# copia — Compiler-owned copia set-algebra methodi
# =============================================================================
#
# What this teaches:
#   • Compiler-owned copia set-algebra methodi.
#   • Related keywords: copia, intrinseca
#
# Common mistakes:
#   • Expecting set operations to modify in-place — `.unio()`, `.intersectio()`, `.differentia()` return new copia values; they do not mutate the receiver.
#
# See also: copia, intrinseca
# =============================================================================

# copia<T> set-algebra intrinsics
#
# Compiler-owned copia<T> methodi — unio, intersectio, differentia,
# symmetrica, subcopia, supercopia.
#
# GRAMMAR:
#   a.unio(b) | a.intersectio(b) | a.differentia(b) | a.symmetrica(b)
#   a.subcopia(b) | a.supercopia(b)
#
# Set operations return new copia<T> values; operands are not mutated.
#
# EXPECTED OUTPUT:
#   Smoke asserts exit 0 only.
#
# BACKEND: Go e2e whitelist — copia method surface not yet lowered for Go.

incipit {
    varia copia<numerus> primi ← vacua
    primi.adde(1)
    primi.adde(2)
    primi.adde(3)

    varia copia<numerus> pares ← vacua
    pares.adde(2)
    pares.adde(4)
    pares.adde(6)

    fixum _ omnes ← primi.unio(pares)
    fixum _ communia ← primi.intersectio(pares)
    fixum _ reliqua ← primi.differentia(pares)
    fixum _ disiuncta ← primi.symmetrica(pares)
    fixum _ subcopiaest ← communia.subcopia(omnes)
    fixum _ supercopiaest ← omnes.supercopia(communia)

    nota omnes, communia, reliqua, disiuncta
    nota subcopiaest, supercopiaest
}
