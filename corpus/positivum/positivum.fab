# =============================================================================

# positivum — retired prefix predicate
#
# GRAMMAR:
#   value > 0
#
# EXPECTED OUTPUT:
#   Scalar stdout smoke (see body).
#

incipit {
    fixum _ value ← 7
    nota value > 0
}
