# sermo.tuus<T>() — typed inbound frame stream

incipit {
    fixum sermo s ← ad 'runtime:echo' ("salve")

    itera ex s.tuus<textus>().cursor() fixum frame {
        adfirma frame.data ≡ "salve"
    }
}