#!/usr/bin/env bash
# HV-04C: Hello Voxel browser proof harness (honest gate).
#
# Builds the hello-voxel Faber package, runs structural mount tests, and
# requires complete HV-04C gate evidence. Missing resize / model-matrix /
# live GPU submit / pixel / depth evidence is a hard failure — never "all
# checks passed" while gaps remain.
#
# Forbidden success proxies:
#   - static public/draw.json alone as drawIndexed GPU proof
#   - MANUAL browser steps documented as pass
#   - SKIP resize treated as pass
#
# Usage:
#   ./scripta/check-hello-voxel-proof           # build + check
#   ./scripta/check-hello-voxel-proof check     # existing artifacts only
#   ./scripta/check-hello-voxel-proof build     # build only

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
HELLO_VOXEL="$REPO_ROOT/hello-voxel"
FABER_BIN="${FABER:-$REPO_ROOT/../faber/target/debug/faber}"
WORKSPACE_ROOT="$(cd "$REPO_ROOT/.." && pwd)"

usage() {
  cat >&2 <<'USAGE'
usage: ./scripta/check-hello-voxel-proof [build|check]

Commands:
  (default)  Build hello-voxel and run all checks.
  build      Build hello-voxel only.
  check      Run checks on existing build artifacts.
USAGE
}

build_package() {
  echo "--- Building hello-voxel package ---"
  cat > "$HELLO_VOXEL/faber.lock" <<LOCK

[[package]]
name = "web"
version = "0.1.0"
source = "path"
package_root = "$WORKSPACE_ROOT/faber-web"
kind = "lib"
target_language = "ts"
target_triple = "browser"
target_manifest = ""
interface_root = "$WORKSPACE_ROOT/faber-web/src"
artifact = ""
crate = "web"
rustc = ""
LOCK

  ( cd "$HELLO_VOXEL" && "$FABER_BIN" build --package . )
}

run_checks() {
  local exit_code=0

  echo ""
  echo "--- Checking HV-03 controller mount ---"
  if node --import "$REPO_ROOT/browser-app/tests/register-hooks.mjs" \
         "$HELLO_VOXEL/tests/browser-fixture-test.mjs" 2>&1; then
    echo "PASS: HV-03 controller mount"
  else
    echo "FAIL: HV-03 controller mount" >&2
    exit_code=1
  fi

  echo ""
  echo "--- Checking HV-04C proof harness (hard-fail incomplete gates) ---"
  if node --import "$REPO_ROOT/browser-app/tests/register-hooks.mjs" \
         "$HELLO_VOXEL/tests/cube-proof-test.mjs" 2>&1; then
    echo "PASS: HV-04C proof harness (all gates complete)"
  else
    echo "FAIL: HV-04C proof harness incomplete or failed" >&2
    exit_code=1
  fi

  echo ""
  echo "--- Checking dist artifact structure ---"
  local missing=0
  local required_paths=(
    "dist/faber-esm/faber-browser.js"
    "dist/faber-esm/main.js"
    "dist/faber-ts/main.ts"
    "dist/controllers.json"
    "dist/assets.json"
    "dist/pages/index.html"
    "dist/styles/main.css"
    "dist/public/draw.json"
  )
  for p in "${required_paths[@]}"; do
    if [ -f "$HELLO_VOXEL/$p" ]; then
      echo "  found: $p"
    else
      echo "  MISSING: $p" >&2
      missing=1
    fi
  done

  if [ "$missing" -eq 0 ]; then
    echo "PASS: required dist package artifacts present"
  else
    echo "FAIL: missing dist artifacts" >&2
    exit_code=1
  fi

  echo ""
  echo "--- Checking HV-04B live geometry emission (not soft-pass) ---"
  # Package-owned geometry/transform binaries for host consume. Missing is a
  # gate gap (hand-2 HV-04B ownership). Do not green-wash absence.
  local hvb_paths=(
    "dist/generated/vertex-positions.bin"
    "dist/generated/vertex-colors.bin"
    "dist/generated/indices.bin"
    "dist/generated/transform.bin"
  )
  local hvb_missing=0
  for p in "${hvb_paths[@]}"; do
    if [ -f "$HELLO_VOXEL/$p" ]; then
      echo "  present: $p"
    else
      echo "  MISSING: $p" >&2
      hvb_missing=1
    fi
  done
  if [ "$hvb_missing" -eq 0 ]; then
    echo "PASS: HV-04B generated geometry/transform binaries present"
  else
    echo "FAIL: HV-04B live geometry/transform binaries missing (not a soft-pass)" >&2
    exit_code=1
  fi

  echo ""
  echo "--- Checking HV-04C live host evidence files ---"
  # Real host submit + pixel capture. Static draw.json is forbidden as proxy.
  local proof_paths=(
    "dist/proof/hv-04c-submit-evidence.json"
    "dist/proof/hv-04c-pixel-evidence.json"
    "dist/proof/hv-04c-depth-evidence.json"
  )
  local proof_missing=0
  for p in "${proof_paths[@]}"; do
    if [ -f "$HELLO_VOXEL/$p" ]; then
      echo "  present: $p"
    else
      echo "  MISSING: $p" >&2
      proof_missing=1
    fi
  done
  if [ "$proof_missing" -eq 0 ]; then
    echo "PASS: HV-04C live host evidence files present"
  else
    echo "FAIL: HV-04C live host evidence missing (fail closed; no MANUAL soft-pass)" >&2
    exit_code=1
  fi

  echo ""
  if [ "$exit_code" -eq 0 ]; then
    echo "=== HV-04C: all checks passed (gates complete) ==="
  else
    echo "=== HV-04C: INCOMPLETE — gate evidence missing or checks FAILED ===" >&2
    echo "=== residual: HV-04B geometry/on_resize/model-matrix (hand-2) + hosts/webgpu-browser proof path for real pixels ===" >&2
  fi
  return "$exit_code"
}

if [ $# -eq 0 ] || [ "$1" = "build" ]; then
  if [ $# -eq 1 ] && [ "$1" = "build" ]; then
    build_package
    exit 0
  fi
  if [ $# -eq 0 ]; then
    build_package
  fi
fi

if [ $# -eq 0 ] || [ "$1" = "check" ]; then
  run_checks
fi
